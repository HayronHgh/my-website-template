{
  "name": "portfolio-content-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "package:dist": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/package-dist.ps1",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:content": "tsx scripts/validate-content.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "pnpm audit --audit-level moderate && pnpm typecheck && pnpm validate:content && pnpm test:run && pnpm lint && pnpm build"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "flatted": "3.4.2",
      "picomatch@<3": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "brace-expansion@<2": "1.1.13",
      "brace-expansion@>=4 <5.0.6": "5.0.6",
      "postcss": "8.5.15",
      "vite": "8.0.16",
      "js-yaml": "4.2.0"
    }
  }
}
